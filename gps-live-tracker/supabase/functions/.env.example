# Supabase URL (e.g. https://your-project-ref.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Publishable Key (Anon Key)
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Supabase Secret Key (Service Role Key - DO NOT COMMIT THE ACTUAL KEY TO VERSION CONTROL)
SUPABASE_SECRET_KEY=your-secret-service-role-key

# Supabase JWKS URL (e.g. https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json)
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
